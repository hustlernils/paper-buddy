# Build stage
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src
COPY . .
RUN dotnet restore "PaperBuddy.Web/PaperBuddy.Web.csproj"
RUN dotnet publish "PaperBuddy.Web/PaperBuddy.Web.csproj" --configuration Release --output /app/publish

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .
EXPOSE 8080
ENTRYPOINT ["dotnet", "PaperBuddy.Web.dll"]